# Afiya — Environment variables example
# Copy this file to .env and fill in your values.
# These are entered directly in the app's Profile screen (stored securely on device).
# This file is only for reference — the app does NOT read a .env file at runtime.

# Oura Ring Personal Access Token
# Get it at: https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=your_oura_personal_access_token_here

# Anthropic API Key (for Claude-powered daily advice)
# Get it at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
